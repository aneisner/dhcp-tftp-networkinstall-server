menuentry 'Install SLES 15 SP7 (aarch64 Network)' --class os {
    echo "Lade aarch64 Kernel..."
    # KEIN Slash vor sles15sp7
    linux /sles15sp7/boot/aarch64/linux \
        install=http://192.168.1.10/repo/sles15sp7/ \
        console=ttyAMA0,115200n8 console=tty0 \
        splash=silent

    echo "Lade aarch64 Initrd..."
    # KEIN Slash vor sles15sp7
    initrd /sles15sp7/boot/aarch64/initrd
