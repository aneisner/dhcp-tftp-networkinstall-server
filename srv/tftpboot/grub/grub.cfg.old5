#    console=tty0 console=ttyAMA0,115200n8

#initrd (tftp,192.168.1.1)/sles15sp7/boot/aarch64/initrd

set debug=all
set root=(tftp,192.168.1.1)

linux /sles15sp7/boot/aarch64/linux \
    install=http://192.168.1.1/sles15sp7/ \
    #console=tty0 console=ttyAMA0,115200n8

initrd /sles15sp7/boot/aarch64/initrd
